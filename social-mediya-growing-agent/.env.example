MAKE_WEBHOOK_URL=https://hook.make.com/your_webhook_here
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/growing-agent-webhook

# ── General Settings ──
POST_INTERVAL_HOURS=6
BRAND_NAME=Whitlogic
