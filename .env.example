# ── Gemini AI API Keys (comma separated, rotates automatically) ──
GEMINI_API_KEYS=AIzaSyXXXXXXXXXXXXXXXXXXXXXX,AIzaSyYYYYYYYYYYYYYYYYYYYYYY

# ── ScrapingAnt API Keys (Amazon scraping) ──
SCRAPINGANT_API_KEYS=your_scrapingant_key_here

# ── Supabase Database ──
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Website API (Next.js) ──
NEXT_API_URL=https://whitlogic.online/api/posts
BOT_API_SECRET=your_secret_key_here

# ── Cloudinary (Image Processing) ──
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── AUTO-PILOT SETTINGS ──
RUN_MODE=autopilot
AUTO_MODE=True
AUTOPILOT_INTERVAL_HOURS=6
AUTO_MAX_KEYWORDS=3
AUTO_MAX_ARTICLES=5
AUTO_PRODUCTS_PER_KW=2

# ── Telegram Bot Alerts (optional but recommended) ──
# 1. @BotFather এ /newbot করুন → token পাবেন
# 2. Bot কে message করুন → chat_id পাবেন: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── n8n Social Media Webhook ──
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/amazon-master-webhook
MAKE_WEBHOOK_URL=https://hook.make.com/your_webhook_here

# ── Automation Key ──
AUTO_KEY=your_automation_trigger_key
